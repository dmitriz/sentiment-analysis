# Minimal Environment Configuration
# Copy this file to .env and add your API keys

# Required: Grok API for X data access
GROK_API_KEY=
# Get from: https://grok.com/api (follow tutorial instructions)

# Required: n8n webhook for workflow automation  
N8N_WEBHOOK_URL=
# Get from: Your n8n instance webhook URL

# Optional: Supabase for advanced features
# SUPABASE_PROJECT_URL=
# SUPABASE_ANON_KEY=
# Get from: https://supabase.com/dashboard (create new project)

# Application settings (has defaults)
# APP_PORT=3000
# NODE_ENV=development
